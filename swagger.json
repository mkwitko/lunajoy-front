                  },
                  "symptomSeverity": {
                    "type": "string",
                    "enum": [
                      "MILD",
                      "MODERATE",
                      "SEVERE"
                    ]
                  },
                  "symptomsDescription": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "symptomType",
                  "symptomSeverity",
                  "symptomsDescription"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
