    "/daily-log": {
      "post": {
        "operationId": "createDailyLog",
        "summary": "Add mood to daily log",
        "tags": [
          "Daily Log"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "date": {
                    "type": "string"
                  },
                  "mood": {
                    "type": "string",
                    "enum": [
                      "VERY_SAD",
                      "SAD",
                      "NEUTRAL",
                      "HAPPY",
                      "VERY_HAPPY"
                    ]
                  },
                  "anxietyLevel": {
                    "type": "string",
                    "enum": [
                      "CALM",
                      "SLIGHTLY_ANXIOUS",
                      "MODERATE",
                      "HIGH",
                      "OVERWHELMED"
                    ]
                  },
                  "physicalActivity": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "durationInMinutes": {
                          "type": "number",
                          "minimum": 0
                        },
                        "activityType": {
                          "type": "string",
                          "enum": [
                            "WALKING",
                            "RUNNING",
                            "CYCLING",
                            "SWIMMING",
                            "YOGA",
                            "OTHER"
                          ]
                        },
                        "intensity": {
                          "type": "string",
                          "enum": [
                            "LOW",
                            "MODERATE",
                            "HIGH"
                          ]
                        },
                        "satisfactionLevel": {
                          "type": "string",
                          "enum": [
                            "VERY_DISSATISFIED",
                            "DISSATISFIED",
                            "NEUTRAL",
                            "SATISFIED",
                            "VERY_SATISFIED"
                          ]
                        }
                      },
                      "required": [
                        "durationInMinutes",
                        "activityType",
                        "intensity",
                        "satisfactionLevel"
                      ]
                    }
                  },
                  "sleep": {
                    "type": "object",
                    "properties": {
                      "sleepDurationInHours": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 24
                      },
                      "sleepQualityRating": {
                        "type": "string",
                        "enum": [
                          "VERY_POOR",
                          "POOR",
                          "AVERAGE",
                          "GOOD",
                          "EXCELLENT"
                        ]
                      },
                      "disturbances": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "sleepDurationInHours",
                      "sleepQualityRating"
                    ]
                  },
                  "socialInteractions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "interactionType": {
                          "type": "string",
                          "enum": [
                            "FAMILY",
                            "FRIENDS",
                            "COLLEAGUES",
                            "STRANGERS",
                            "WORK",
                            "SHOPPING",
                            "OTHER"
                          ]
                        },
                        "satisfactionLevel": {
                          "type": "string",
                          "enum": [
                            "VERY_DISSATISFIED",
                            "DISSATISFIED",
                            "NEUTRAL",
                            "SATISFIED",
                            "VERY_SATISFIED"
                          ]
                        },
                        "duration": {
                          "type": "number",
                          "minimum": 0
                        }
                      },
                      "required": [
                        "interactionType",
                        "satisfactionLevel",
                        "duration"
                      ]
                    }
                  },
                  "stressLevel": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "stressLevelType": {
                          "type": "string",
                          "enum": [
                            "LOW",
                            "MODERATE",
                            "HIGH",
                            "EXTREME"
                          ]
                        },
                        "duration": {
                          "type": "number",
                          "minimum": 0
                        },
                        "situationDescription": {
                          "type": "string"
                        },
                        "stressSource": {
                          "type": "string",
                          "enum": [
                            "WORK",
                            "FAMILY",
                            "HEALTH",
                            "FINANCES",
                            "RELATIONSHIPS",
                            "OTHER"
                          ]
                        }
                      },
                      "required": [
                        "stressLevelType",
                        "duration"
                      ]
                    }
                  },
                  "symptoms": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "symptomType": {
                          "type": "string",
                          "enum": [
                            "SADNESS",
                            "FATIGUE",
                            "IRRITABILITY",
                            "LACK_OF_FOCUS",
                            "ANXIETY",
                            "INSOMNIA",
                            "LOSS_OF_INTEREST",
                            "RESTLESSNESS"
                          ]
                        },
                        "symptomSeverity": {
                          "type": "string",
                          "enum": [
                            "MILD",
                            "MODERATE",
                            "SEVERE"
                          ]
                        },
                        "symptomsDescription": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "symptomType",
                        "symptomSeverity",
                        "symptomsDescription"
                      ]
                    }
                  }
                },
                "required": [
                  "mood",
                  "anxietyLevel",
                  "sleep"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "409": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      },
      "delete": {
