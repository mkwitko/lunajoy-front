    "/daily-log/anxiety": {
      "post": {
        "summary": "Add anxiety level to daily log",
        "tags": [
          "Daily Log"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "anxietyLevelInformed": {
                    "type": "string",
                    "enum": [
                      "CALM",
                      "SLIGHTLY_ANXIOUS",
                      "MODERATE",
                      "HIGH",
                      "OVERWHELMED"
                    ]
                  }
                },
                "required": [
                  "anxietyLevelInformed"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/daily-log/symptoms": {
      "post": {
        "summary": "Add symptom to daily log",
        "tags": [
          "Daily Log"
        ],
        "requestBody": {
          "required": true,
